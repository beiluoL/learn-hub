# ===== LearnHub 环境变量（复制到 .env 后填写，.env 不要提交） =====

# Supabase（登录注册 + 学习进度存储）
# 复制自 Supabase 控制台 Settings → API
# - VITE_SUPABASE_URL 例如 https://xxxx.supabase.co
# - VITE_SUPABASE_PUBLISHABLE_KEY 即 publishable anon key（公开安全）
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Umami 访问统计（复制自 Umami 后台「添加网站」后的 website id）
VITE_UMAMI_ID=
